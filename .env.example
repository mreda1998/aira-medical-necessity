OPENAI_API_KEY=sk-...
MISTRAL_API_KEY=...

# Primary extraction model. gpt-4o compiles a new guideline in ~20s; gpt-5.x
# reasoning models are more accurate but noticeably slower on first compile
# (the compiled tree is cached, so later runs are fast either way).
PRIMARY_MODEL=gpt-4o
VERIFIER_MODEL=mistral-large-latest
CACHE_DIR=/data/guidelines

# Observability / debugging (optional)
# LOG_LEVEL=INFO      # set to DEBUG to log full LLM prompts + responses
# AIRA_DEBUG=1        # capture every pipeline step's JSON on every request
# DEBUG_DIR=/data/debug   # where per-step JSON trace files are written
